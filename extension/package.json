{
  "name": "pq-webauthn-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "setup": "bun run setup:liboqs:wasm && bun run build:wasm",
    "build": "vite build",
    "build:all": "bun run build:wasm && bun run build",
    "setup:liboqs:wasm": "bash scripts/setup-liboqs-emscripten.sh",
    "build:wasm": "bash scripts/build-liboqs-wasm.sh",
    "build:native-host:macos": "bash scripts/build-native-host-macos.sh",
    "install:native-host:macos": "bash scripts/install-native-host-macos.sh",
    "setup:touch-id:macos": "bash scripts/setup-touch-id-uv-macos.sh",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.292",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
